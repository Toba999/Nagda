<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/excuseFragment"
        android:name="com.dev.dwamy.features.excuse.presentation.view.ExcuseFragment"
        android:label="fragment_excuse"
        tools:layout="@layout/fragment_excuse" >
        <action
            android:id="@+id/action_excuseFragment_to_successDialogFragment"
            app:destination="@id/successDialogFragment" />
    </fragment>
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.dev.dwamy.features.profile.presentation.view.ProfileFragment"
        android:label="fragment_profile"
        tools:layout="@layout/fragment_profile" />
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.dev.dwamy.features.home.presentation.view.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_vacationRequestFragment"
            app:destination="@id/vacationRequestFragment" />
        <action
            android:id="@+id/action_homeFragment_to_excuseRequestFragment"
            app:destination="@id/excuseRequestFragment" />
        <action
            android:id="@+id/action_homeFragment_to_successDialogFragment"
            app:destination="@id/successDialogFragment" />
    </fragment>
    <fragment
        android:id="@+id/vacationFragment"
        android:name="com.dev.dwamy.features.vacation.presentation.view.VacationFragment"
        android:label="fragment_vacation"
        tools:layout="@layout/fragment_vacation" >
        <action
            android:id="@+id/action_vacationFragment_to_successDialogFragment"
            app:destination="@id/successDialogFragment" />
    </fragment>
    <fragment
        android:id="@+id/excuseRequestFragment"
        android:name="com.dev.dwamy.features.excuseRequest.presentation.view.ExcuseRequestFragment"
        android:label="fragment_excuse_request"
        tools:layout="@layout/fragment_excuse_request" >
        <action
            android:id="@+id/action_excuseRequestFragment_to_successDialogFragment"
            app:destination="@id/successDialogFragment" />
    </fragment>
    <fragment
        android:id="@+id/vacationRequestFragment"
        android:name="com.dev.dwamy.features.vacationRequest.presentation.view.VacationRequestFragment"
        android:label="fragment_vacation_request"
        tools:layout="@layout/fragment_vacation_request" >
        <action
            android:id="@+id/action_vacationRequestFragment_to_successDialogFragment"
            app:destination="@id/successDialogFragment" />
    </fragment>

    <dialog
        android:id="@+id/successDialogFragment"
        android:name="com.dev.dwamy.features.dialogs.SuccessDialogFragment"
        android:label="Success Dialog"
        tools:layout="@layout/fragment_success_dialog"
        android:theme="@style/Theme.MaterialComponents.Light.Dialog.Alert">
        <argument
            android:name="title"
            app:argType="string"
            android:defaultValue="تم تقديم الطلب بنجاح"/>
        <argument
            android:name="icon"
            app:argType="string"
            android:defaultValue="0"/>
    </dialog>

    <dialog
        android:id="@+id/logoutDialogFragment"
        android:name="com.dev.dwamy.features.dialogs.LogoutDialogFragment"
        android:label="Logout Dialog"
        tools:layout="@layout/fragment_logout_dialog"
        android:theme="@style/Theme.MaterialComponents.Light.Dialog.Alert">
        <action
            android:id="@+id/action_logoutDialogFragment_to_LoginFragment"
            app:destination="@id/LoginFragment"
            app:popUpTo="@id/containerFragment"
            app:popUpToInclusive="true"/>
    </dialog>


</navigation>