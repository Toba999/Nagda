<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screenBackground"
    android:layoutDirection="rtl">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:fontFamily="@font/notokufi_arabic_semibold"
        android:text="@string/main"
        android:textColor="@color/primaryText"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvWarning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/notokufi_arabic_medium"
        android:gravity="center"
        android:text="@string/call_when_emergency"
        android:textColor="@color/primaryText"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <ImageView
        android:id="@+id/tvBtnSosImg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:gravity="center"
        android:src="@drawable/ic_info"
        android:textColor="@color/white"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationZ="2dp"
        app:layout_constraintTop_toTopOf="@+id/btnSOS"
        app:layout_constraintBottom_toTopOf="@id/tvBtnSosText"/>

    <TextView
        android:id="@+id/tvBtnSosText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="90dp"
        android:fontFamily="@font/notokufi_arabic_medium"
        android:gravity="center"
        android:text="@string/Sos_text"
        android:textColor="@color/white"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationZ="2dp"
        app:layout_constraintTop_toTopOf="@+id/btnSOS"
        app:layout_constraintBottom_toBottomOf="@id/btnSOS"/>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/btnSOS"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="32dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvWarning"
        app:lottie_autoPlay="true"
        app:lottie_rawRes="@raw/emergency_btn"
        app:lottie_loop="true" />

    <Button
        android:id="@+id/btnCall"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/color_call"
        android:fontFamily="@font/notokufi_arabic_medium"
        android:text="@string/call_police"
        android:textColor="@color/white"
        android:textSize="15sp"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnSOS" />

    <ImageView
        android:id="@+id/tvBtnCallImg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_call"
        android:translationZ="2dp"
        android:layout_marginStart="60dp"
        app:layout_constraintStart_toStartOf="@+id/btnCall"
        app:layout_constraintTop_toTopOf="@+id/btnCall"
        app:layout_constraintBottom_toBottomOf="@id/btnCall"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSafety"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#FFFFFF"
        android:drawableStart="@drawable/ic_safety"
        android:drawablePadding="8dp"
        android:fontFamily="@font/notokufi_arabic_medium"
        android:text="@string/safety_measurement"
        android:textColor="@color/color_call"
        android:textSize="15sp"
        app:cornerRadius="12dp"
        app:strokeColor="@color/strokeColor"
        app:strokeWidth="1dp"
        app:elevation="4dp"
        android:stateListAnimator="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnCall" />
    <ImageView
        android:id="@+id/tvBtnSafetyImg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_safety"
        android:translationZ="2dp"
        android:layout_marginStart="92dp"
        app:layout_constraintStart_toStartOf="@+id/btnSafety"
        app:layout_constraintTop_toTopOf="@+id/btnSafety"
        app:layout_constraintBottom_toBottomOf="@id/btnSafety"/>
    <include
        android:id="@+id/loadingView"
        layout="@layout/loading_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
